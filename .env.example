# Application
APP_ENV=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/ct_cga_agent
# For local dev/testing, use SQLite:
# DATABASE_URL=sqlite:///./var/ct_cga_agent.db

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./var/storage

# S3 (optional)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# LLM
OPENAI_API_KEY=
OPENAI_MODEL_SUMMARY=gpt-4o
OPENAI_MODEL_REASONING=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false

# CGA Scraping
CGA_REQUEST_TIMEOUT_SECONDS=30
CGA_POLL_INTERVAL_MINUTES=20

# OCR
OCR_ENABLED=true
TESSERACT_CMD=tesseract

# Session
DEFAULT_TIMEZONE=America/New_York
SESSION_YEAR=2026
